{
  "manifest_version": 2,
  "name": "GAFAM Blocker",
  "version": "1.0",
  "description": "Blockiert alle Dienste von GAFAM und zeigt eine Alternativ-Seite.",
  "icons": {
    "48": "icon.png",
    "96": "icon.png"
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icon.png"
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "<all_urls>",
    "storage"
  ],
  "web_accessible_resources": ["blocked.html"],
  "background": {
    "scripts": ["background.js"]
  }
}